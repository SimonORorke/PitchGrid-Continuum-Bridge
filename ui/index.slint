import {
    ComboBox,
    MagicText,
    MagicWindow,
    OutlineButton,
} from "@vivi/magic.slint";

import { MessageText, MessageType } from "components/message_text.slint";

export component MainWindow inherits MagicWindow {
    width: 600px;
    height: 200px;
    title: window_title;
    icon: Globals.icon;
    forward-focus: output_ports_combo;

    in property output_ports_model <=> output_ports_combo.model;
    in property <string> window_title;
    
    callback output_port_changed(index: int);
    callback refresh_output_ports();

    public function show_message(message: string, message_type: MessageType) {
        message_text.text = message;
        message_text.message_type = message_type;
    }

    GridLayout {
        HorizontalLayout {
            row: 0;
            VerticalLayout {
                padding_right: 5px;
                Image {
                    source: Globals.icon;
                    width: 50px; height: 50px;
                }
            }
            MagicText {
                text: "MIDI Output:";
                vertical_alignment: center;
                width: 100px;
            }
            VerticalLayout {
                padding_left: 5px;
                padding_top: 10px;
                padding_right: 10px;
                output_ports_combo := ComboBox {
                    current_index: 0;
                    changed current_index => {
                        root.output_port_changed(self.current_index)
                    }
                    height: 30px;
                    width: 280px;
                }
            }
            VerticalLayout {
                padding_top: 10px;
                OutlineButton {
                    text: "Refresh Ports";
                    clicked => {
                        root.refresh_output_ports()
                    }
                    height: 30px;
                    width: 140px;
                }
            }
        }
        HorizontalLayout {
            row: 1;
            padding_top: 105px;
            Rectangle {
                width: root.width;
                height: 50px;
                message_text := MessageText {
                    vertical_alignment: center;
                }
            }
        }
    }
}

global Globals {
    out property<image> icon: @image-url("images/Midi port black on red 512.png");
}
