import {
    ComboBox,
    FilledButton,
    MagicHorizontalBox,
    MagicVerticalBox,
    MagicText,
    MagicWindow
} from "@vivi/magic.slint";

export component MainWindow inherits MagicWindow {
    min-width: 400px; // Min is also initial
    min-height: 200px; // Min is also initial
    max-height: 600px; // Min does not work if max not set.
    title: window_title;
    icon: Globals.icon;

    in-out property midi_input_index <=> midi-inputs-combo.current-index;
    in property midi_inputs <=> midi-inputs-combo.model;
    in property <string> window_title;
    
    callback midi_input_changed(index: int);

    GridLayout {
        spacing: 5px;
        Image {
            source: Globals.icon;
            width: 50px; height: 50px;
        }
        MagicText {
            text: "MIDI Input:";
            vertical-alignment: center;
        }
        VerticalLayout {
            padding-right: 10px;
            padding-top: 10px;
            midi-inputs-combo := ComboBox {
//                model: [
//                    { text: "First" },
//                    { text: "Second" },
//                    { text: "Third" }
//                ];
                current-index: 0;
                changed current-index => {
                    root.midi_input_changed(self.current-index)
                }
                height: 30px;
            }
        }
    }
}

global Globals {
    out property<image> icon: @image-url("images/Midi port black on red 512.png");
}
