import {
    ComboBox,
    MagicText,
    MagicWindow,
    OutlineButton,
} from "@vivi/magic.slint";

import { MessageText, MessageType } from "components/message_text.slint";

export component MainWindow inherits MagicWindow {
    width: 600px;
    height: 200px;
    title: window_title;
    icon: Globals.icon;
    forward-focus: output_ports_combo;

    in property output_ports_model <=> output_ports_combo.model;
    out property <int> selected_output_port_index;
    in property <string> window_title;
    
    callback connect_to_output_port();
    callback refresh_output_ports();

    public function show_message(message: string, message_type: MessageType) {
        message_text.text = message;
        message_text.message_type = message_type;
    }

    GridLayout {
        HorizontalLayout {
            row: 0;
            VerticalLayout {
                padding_right: Globals.horizontal_padding;
                Image {
                    source: Globals.icon;
                    width: Globals.row_height;
                    height: Globals.row_height;
                }
            }
            MagicText {
                text: "MIDI Output:";
                vertical_alignment: center;
                width: 100px;
            }
            VerticalLayout {
                padding_left: Globals.horizontal_padding;
                padding_top: Globals.vertical_padding;
                padding_right: Globals.horizontal_padding * 2;
                output_ports_combo := ComboBox {
                    current_index: 0;
                    changed current_index => {
                        root.selected_output_port_index = self.current_index;
                    }
                    height: Globals.control_height;
                    width: 280px;
                }
            }
            VerticalLayout {
                padding_top: Globals.vertical_padding;
                OutlineButton {
                    text: "Connect";
                    clicked => {
                        root.connect_to_output_port()
                    }
                    height: Globals.control_height;
                    width: Globals.button_width;
                }
            }
        }
        HorizontalLayout {
            row: 1;
            Rectangle {
                width: root.width - Globals.button_width - Globals.horizontal_padding * 2;
                height: Globals.row_height;
            }
            VerticalLayout {
                OutlineButton {
                    text: "Refresh Ports";
                    clicked => {
                        root.refresh_output_ports()
                    }
                    height: Globals.control_height;
                    width: Globals.button_width;
                }
            }
        }
        HorizontalLayout {
            row: 2;
            Rectangle {
                width: root.width;
                height: 0px; // Why does this work?
                message_text := MessageText {
                    vertical_alignment: center;
                }
            }
        }
    }
}

global Globals {
    out property<length> button_width: 140px;
    out property<length> control_height: 30px;
    out property<length> horizontal_padding: 5px;
    out property<image> icon: @image-url("images/Midi port black on red 512.png");
    out property<length> row_height: 50px;
    out property<length> vertical_padding: 10px;
}
