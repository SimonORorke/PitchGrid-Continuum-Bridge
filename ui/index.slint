import {
    ComboBox,
    FilledButton,
    MagicHorizontalBox,
    MagicVerticalBox,
    MagicText,
    MagicWindow
} from "@vivi/magic.slint";

export component MainWindow inherits MagicWindow {
    width: 400px;
    height: 300px;
    title: window_title;
    icon: Globals.icon;

    in property <string> window_title;

    MagicHorizontalBox {
        Image {
            source: Globals.icon;
            width: 50px; height: 50px;
        }
        MagicText {
            text: "Input:";
            height: 50px;
            vertical_alignment: center;
        }
        ComboBox {
            model: [
                { text: "First" },
                { text: "Second" },
                { text: "Third" }
            ];
            current_index: 0;
            height: 50px;
        }
    }
}

global Globals {
    out property<image> icon: @image-url("images/Midi port black on red 512.png");
}
