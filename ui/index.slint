import {
    ComboBox,
    MagicText,
    MagicWindow,
    OutlineButton,
} from "@vivi/magic.slint";

export component MainWindow inherits MagicWindow {
    width: 600px;
    height: 200px;
    title: window_title;
    icon: Globals.icon;

    in property midi_outputs_model <=> midi-outputs-combo.model;
    in property <string> window_title;
    
    callback midi_output_changed(index: int);
    callback refresh_midi_outputs();

    GridLayout {
        spacing: 5px;
        Row {
            VerticalLayout {
                Image {
                    source: Globals.icon;
                    width: 50px; height: 50px;
                }
            }
            MagicText {
                text: "MIDI Output:";
                vertical-alignment: center;
                width: 100px;
            }
            VerticalLayout {
                padding-top: 10px;
                padding-right: 5px;
                midi-outputs-combo := ComboBox {
                    current-index: 0;
                    changed current-index => {
                        root.midi_output_changed(self.current-index)
                    }
                    height: 30px;
                    width: 280px;
                }
            }
            VerticalLayout {
                padding-top: 10px;
                OutlineButton {
                    text: "Refresh Ports";
                    clicked => {
                        root.refresh_midi_outputs()
                    }
                    height: 30px;
                    width: 140px;
                }
            }
        }
    }
}

global Globals {
    out property<image> icon: @image-url("images/Midi port black on red 512.png");
}
