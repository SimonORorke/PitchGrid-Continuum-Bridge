import {
    ButtonAction,
    ComboBox,
    FilledButton,
    GroupBox,
    MagicText,
    MagicWindow,
} from "@vivi/magic.slint";
import { MessageText, MessageType, ParamName, ParamValue } from "components/text.slint";
import { MidiIo } from "components/midi_io.slint";
import { Globals } from "globals.slint";
import { Palette, VerticalBox, } from "std-widgets.slint";

export component MainWindow inherits MagicWindow {
    background: get_background_color();
    width: 700px;
    // Needs to be big enough to include everything down to the first status bar line.
    // Expands automatically if the status message does not fit.
    min_height: 505px;
    title: window_title;
    icon: Globals.icon;
    forward-focus: midi_input;

    in property depth <=> depth_value.text;
    in property root_freq <=> root_freq_value.text;
    in property stretch <=> stretch_value.text;
    in property skew <=> skew_value.text;
    in property mode_offset <=> mode_offset_value.text;
    in property <int> selected_tuning_grid_index;
    in property steps <=> steps_value.text;
    in property tuning_grids_model <=> tuning_grids_combo.model;
    in property <string> window_title;

    callback selected_tuning_grid_changed(index: int);
    callback update_tuning();

    public function show_message(message: string, message_type: MessageType) {
        message_text.text = message;
        message_text.message_type = message_type;
    }

    public function show_pitchgrid_connection_status(message: string, message_type: MessageType) {
        pitchgrid_connection_status_text.text = message;
        pitchgrid_connection_status_text.message_type = message_type;
    }

    in property input_ports_model <=> midi_input.ports_model;
    in-out property <int> selected_input_port_index <=> midi_input.selected_port_index;
    callback connect_input_port <=> midi_input.connect_port;
    callback refresh_input_ports <=> midi_input.refresh_ports;
    public function show_connected_input_port_name(name: string, message_type: MessageType) {
        midi_input.show_connected_port_name(name, message_type);
    }

    in property output_ports_model <=> midi_output.ports_model;
    in-out property <int> selected_output_port_index <=> midi_output.selected_port_index;
    callback connect_output_port <=> midi_output.connect_port;
    callback refresh_output_ports <=> midi_output.refresh_ports;
    public function show_connected_output_port_name(name: string, message_type: MessageType) {
        midi_output.show_connected_port_name(name, message_type);
    }

    public function focus_output_port() {
        midi_output.focus();
    }

    public function focus_update_tuning_button() {
        update_tuning_button.focus();
    }

    function get_background_color() -> color {
        return Palette.color_scheme == ColorScheme.light ? #BDDFCC : #123735;
    }

    VerticalLayout {
        alignment: start; // Stops spreading out when window lenghthened.
        padding_left: 10px;
        VerticalLayout {
            padding_top: 5px;
            padding-right: 10px;
            GroupBox {
                title: "From PitchGrid";
                width: 680px;
                VerticalLayout {
                    HorizontalLayout {
                        alignment: space-between;
                        ParamName { text: "Depth"; }
                        ParamName { text: "Root Freq"; }
                        ParamName { text: "Stretch"; }
                        ParamName { text: "Skew"; }
                        ParamName { text: "Mode Offset"; }
                        ParamName { text: "Steps"; }
                    }
                    HorizontalLayout {
                        alignment: space-between;
                        depth_value := ParamValue {}
                        root_freq_value := ParamValue {}
                        stretch_value := ParamValue {}
                        skew_value := ParamValue {}
                        mode_offset_value := ParamValue {}
                        steps_value := ParamValue {}
                    }
                }
            }
        }
        VerticalBox {
            padding-top: 10px;
            pitchgrid_connection_status_text := MessageText {
                horizontal_alignment: center;
                vertical_alignment: top;
            }
        }
        HorizontalLayout {
            padding_top: 5px;
            MagicText {
                text: "Tuning grid:";
                vertical_alignment: center;
                width: 90px;
            }
            VerticalLayout {
                padding_left: Globals.horizontal_padding;
                padding_right: Globals.horizontal_padding * 2;
                tuning_grids_combo := ComboBox {
                    current_index: root.selected_tuning_grid_index;
                    changed current_index => {
                        root.selected_tuning_grid_changed(self.current_index);
                    }
                    height: Globals.control_height;
                    width: 55px;
                }
            }
            HorizontalLayout {
                alignment: end;
                padding-right: 20px;
                update_tuning_button := FilledButton {
                    text: "Update Tuning";
                    action: ButtonAction.primary;
                    height: Globals.control_height;
                    width: Globals.button_width;
                    clicked => {
                        root.update_tuning()
                    }
                }
            }
        }
        VerticalLayout {
            padding_top: 10px;
            midi_input := MidiIo {
                group_title: "From Haken/Osmose Editor Instrument Output";
                type_label: "MIDI Input:";
            }
        }
        VerticalLayout {
            padding_top: 15px;
            midi_output := MidiIo {
                group_title: "To Haken Continuum / EaganMatrix Module / Osmose";
                type_label: "MIDI Output:";
            }
        }
        HorizontalLayout {
            padding_top: 10px;
            padding_bottom: 5px;
            HorizontalLayout {
                alignment: start; // Centres the message text.
                Image {
                    source: Globals.icon;
                    width:  Globals.control_height; height: Globals.control_height;
                }
            }
            VerticalBox {
                padding-top: 5px;
                message_text := MessageText {
                    horizontal_alignment: center;
                    vertical_alignment: top;
                }
            }
            HorizontalLayout {
                alignment: end;
                padding-right: 10px;
                FilledButton {
                    prefix_icon: @image-url("images/menu-svgrepo-com.svg");
                    height: Globals.control_height;
                    width: 50px; // Min before icon is not centred.
                }
            }
        }
    }
}
