import {
    ButtonAction,
    ComboBox,
    FilledButton,
    GroupBox,
    MagicText,
    MagicWindow,
    Switch
} from "@vivi/magic.slint";
import { MessageText, SlintMessageType, ParamName, ParamValue } from "components/text.slint";
import { MidiIo } from "components/midi_io.slint";
import { Globals } from "globals.slint";
import { Palette, SpinBox, VerticalBox, } from "std-widgets.slint";

export enum SlintPortType {
    input,
    output
}

export component MainWindow inherits MagicWindow {
    // Overriding the Light/Dark colour scheme to enforce dark mode,
    // as I could not come up with a satisfactory ligth mode variant.
    init => { Palette.color-scheme = ColorScheme.dark; }
    background: get_background_color();
    // Width and height need to be minimums
    // to allow the Window to be bigger on a bigger screen.
    min_width: 700px;
    // Needs to be big enough to include everything down to the second status bar line.
    // Expands automatically if the status message does not fit.
    min_height: 480px;
    title: window_title;
    icon: Globals.icon;
    forward-focus: root_notes_combo;

    in property depth <=> depth_value.text;
    in property root_freq <=> root_freq_value.text;
    in property stretch <=> stretch_value.text;
    in property skew <=> skew_value.text;
    in property mode_offset <=> mode_offset_value.text;
    in property <bool> override_rounding_initial;
    in property <bool> override_rounding_rate;
    in property <int> rounding_rate;
    in property <int> selected_root_note_index;
    in property <int> selected_pitch_table_index;
    in property steps <=> steps_value.text;
    in property root_notes_model <=> root_notes_combo.model;
    in property pitch_tables_model <=> pitch_tables_combo.model;
    in property <string> window_title;

    callback connect_port(port_type: SlintPortType);
    callback refresh_devices(port_type: SlintPortType);
    callback override_rounding_initial_changed(override_rounding_initial: bool);
    callback override_rounding_rate_changed(override_rounding_rate: bool);
    callback open_documentation();
    callback rounding_rate_changed(rounding_rate: int);
    callback selected_root_note_changed(index: int);
    callback selected_pitch_table_changed(index: int);

    function get_background_color() -> color {
        return Palette.color_scheme == ColorScheme.light ? #BDDFCC : #123735;
    }

    public function show_message(message: string, message_type: SlintMessageType) {
        message_text.text = message;
        message_text.message_type = message_type;
    }

    public function show_pitchgrid_status(message: string, message_type: SlintMessageType) {
        pitchgrid_status_text.text = message;
        pitchgrid_status_text.message_type = message_type;
    }

    in property input_devices_model <=> midi_io.input_devices_model;
    in-out property <int> input_selected_port_index <=> midi_io.input_selected_port_index;
    public function input_focus() {
        midi_io.input_focus();
    }
    public function input_show_connected_device_name(name: string, message_type: SlintMessageType) {
        midi_io.input_show_connected_device_name(name, message_type);
    }

    in property output_devices_model <=> midi_io.output_devices_model;
    in-out property <int> output_selected_port_index <=> midi_io.output_selected_port_index;
    public function output_focus() {
        midi_io.output_focus();
    }
    public function output_show_connected_device_name(name: string, message_type: SlintMessageType) {
        midi_io.output_show_connected_device_name(name, message_type);
    }

    VerticalLayout {
        alignment: start; // Stops spreading out when window lenghthened.
        padding_left: 10px;
        tuning_params_layout := VerticalLayout {
            padding_top: 5px;
            padding-right: 10px;
            GroupBox {
                title: "From PitchGrid";
                width: 680px;
                VerticalLayout {
                    HorizontalLayout {
                        alignment: space-between;
                        ParamName { text: "Depth"; }
                        ParamName { text: "Root Freq"; }
                        ParamName { text: "Stretch"; }
                        ParamName { text: "Skew"; }
                        ParamName { text: "Mode Offset"; }
                        ParamName { text: "Steps"; }
                    }
                    HorizontalLayout {
                        alignment: space-between;
                        depth_value := ParamValue {}
                        root_freq_value := ParamValue {}
                        stretch_value := ParamValue {}
                        skew_value := ParamValue {}
                        mode_offset_value := ParamValue {}
                        steps_value := ParamValue {}
                    }
                }
            }
        }
        options_line1_layout := HorizontalLayout {
            alignment: space-between;
            padding_left: -10px;
            padding_top: 5px;
            root_freq_layout := HorizontalLayout {
                VerticalBox {
                    height: Globals.control_height;
                    padding-top: 10px;
                    MagicText {
                        text: "Root Freq Override:";
                        vertical_alignment: center;
                    }
                }
                VerticalLayout {
                    padding_top: 5px;
                    root_notes_combo := ComboBox {
                        current_index: root.selected_root_note_index;
                        changed current_index => {
                            root.selected_root_note_changed(self.current_index);
                        }
                        height: Globals.control_height;
                        width: 60px;
                    }
                }
            }
            pitch_table_layout := HorizontalLayout {
                padding_right: 10px;
                VerticalBox {
                    height: Globals.control_height;
                    padding-top: 10px;
                    MagicText {
                        text: "Pitch Table:";
                        vertical_alignment: center;
                    }
                }
                VerticalLayout {
                    padding_top: 5px;
                    pitch_tables_combo := ComboBox {
                        current_index: root.selected_pitch_table_index;
                        changed current_index => {
                            root.selected_pitch_table_changed(self.current_index);
                        }
                        height: Globals.control_height;
                        width: 60px;
                    }
                }
            }
        }
        rounding_overrides_line_layout := HorizontalLayout {
            alignment: space-between;
            padding_left: -10px;
            padding_top: 5px;
            padding_right: 10px;
            rounding_overrides_box := VerticalBox {
                height: Globals.control_height;
                padding-top: 10px;
                MagicText {
                    text: "Rounding Overrides:";
                    vertical_alignment: center;
                }
            }
            override_rounding_initial_layout := VerticalLayout {
                padding_top: 5px;
                override_rounding_initial_switch := Switch {
                    text: "Initial";
                    checked: root.override_rounding_initial;
                    toggled => {
                        root.override_rounding_initial_changed(self.checked);
                    }
                    height: Globals.control_height;
                }
            }
            rounding_rate_options_layout := HorizontalLayout {
                override_rounding_rate_layout := VerticalLayout {
                    padding_top: 5px;
                    override_rounding_rate_switch := Switch {
                        text: "Rate";
                        checked: root.override_rounding_rate;
                        toggled => {
                            root.override_rounding_rate_changed(self.checked);
                        }
                        height: Globals.control_height;
                    }
                }
                rate_layout := VerticalLayout {
                    padding_left: Globals.horizontal_padding;
                    padding_top: 5px;
                    SpinBox {
                        value: root.rounding_rate;
                        maximum: 127;
                        edited => {
                            root.rounding_rate_changed(self.value);
                        }
                        enabled: override_rounding_rate_switch.checked;
                        width: 105px;
                        height: Globals.control_height;
                    }
                }
            }
        }
        pitchgrid_status_box := VerticalBox {
            height: 25px;
            padding-top: 5px;
            pitchgrid_status_text := MessageText {
                horizontal_alignment: center;
                vertical_alignment: top;
            }
        }
        midi_io_layout := VerticalLayout {
            padding_top: 10px;
            midi_io := MidiIo {
                group_title: "From/To Editor All Data External Ports";
                input_connect_port => {
                    root.connect_port(SlintPortType.input)
                }
                output_connect_port => {
                    root.connect_port(SlintPortType.output)
                }
                input_refresh_devices => {
                    root.refresh_devices(SlintPortType.input)
                }
                output_refresh_devices => {
                    root.refresh_devices(SlintPortType.output)
                }
            }
        }
        status_bar_layout := HorizontalLayout {
            padding_top: 5px;
            icon_layout := HorizontalLayout {
                padding_top: 10px;
                alignment: start; // Centres the message text.
                Image {
                    source: Globals.icon;
                    width:  Globals.control_height; height: Globals.control_height;
                }
            }
            status_message_box := VerticalBox {
                padding-top: 15px;
                message_text := MessageText {
                    horizontal_alignment: center;
                }
            }
            HorizontalLayout {
                alignment: end;
                padding_top: 10px;
                padding-right: 10px;
                FilledButton {
                    prefix_icon: @image-url("images/menu-svgrepo-com.svg");
                    height: Globals.control_height;
                    width: 50px; // Min before icon is not centred.
                    clicked => {
                        main_menu.show(self.absolute-position)
                    }
                }
            }
        }
    }
    main_menu := ContextMenuArea {
        Menu {
            MenuItem {
                title: "Documentation...";
                activated => { root.open_documentation(); }
            }
            MenuItem {
                title: "About...";
                activated => { debug("About"); }
            }
        }
    }
}
